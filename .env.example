# Apex DFS AI - Environment Configuration

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/apex_dfs
REDIS_URL=redis://localhost:6379/0

# API Keys
BALLDONTLIE_API_KEY=your_balldontlie_key_here
ODDS_API_KEY=your_the_odds_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
FIREBASE_CREDENTIALS_JSON=path/to/firebase-adminsdk.json

# If set to true, gracefully falls back to mock data when API keys are missing
USE_DEMO_DATA_FALLBACK=true
